# =============================================================================
# Integrated Smart City Traffic Management System - .gitignore
# =============================================================================

# --- Java / Maven Build Artifacts ---
target/
*.class
*.jar
*.war
*.ear
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml

# --- Maven Wrapper ---
.mvn/
mvn.cmd
mvnw
mvnw.cmd

# --- Node.js / Next.js ---
node_modules/
.pnp
.pnp.js
.next/
out/
build/
dist/

# --- Environment Variables (SENSITIVE) ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.properties.local
application-local.properties

# --- Logs ---
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
nohup.out

# --- Runtime PIDs ---
*.pid
integrated-traffic-system/pids/*.pid

# --- Database ---
*.db
*.sqlite

# --- IDE Files ---
# IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr

# Eclipse
.metadata/
.settings/
.project
.classpath
bin/

# VS Code
.vscode/
*.code-workspace

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#
.\#*

# --- OS Files ---
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# --- Test Coverage ---
coverage/
.nyc_output/

# --- TypeScript ---
*.tsbuildinfo

# --- Kafka / Zookeeper Data ---
kafka-logs/
zookeeper/

# --- LaTeX Temporary Files ---
*.aux
*.log
*.out
*.toc
*.synctex.gz
*.fls
*.fdb_latexmk

# --- Backup Files ---
*.bak
*.backup
*.old
*.orig

# --- Temporary Files ---
tmp/
temp/
*.tmp

# --- Package Manager Locks (Optional - uncomment if needed) ---
# package-lock.json
# yarn.lock
# pnpm-lock.yaml
